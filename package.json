{
  "name": "tree-sitter-aspcore2",
  "version": "0.1.0",
  "description": "A tree-sitter grammar for the ASP-Core-2 input language format for ASP (Aswer Set Programming) systems.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/namcsi/tree-sitter-aspcore-2.git"
  },
  "license": "MIT",
  "author": {
    "name": "Amadé Nemes",
    "email": "nemesamade@gmail.com"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "aspcore2"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.3.1",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1",
    "prettier": "3.8.1",
    "tree-sitter-cli": "^0.26.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.22.4"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  }
}
